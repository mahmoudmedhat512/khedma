{
  "expo": {
    "name": "Khedma Delivery App",
    "slug": "khedma-delivery-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "khedmadeliveryapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B3B24"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.khedma-delivery-app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.khedma_delivery_app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Allow Khedma to access your location to find nearby stores and calculate delivery fees.",
          "locationWhenInUsePermission": "Allow Khedma to access your location to find nearby stores and calculate delivery fees."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportsRTL": true,
      "router": {},
      "eas": {
        "projectId": "377e1bb0-ace3-4320-b86d-8e73ba5bb99c"
      }
    },
    "owner": "mahmoud_madhat"
  }
}
